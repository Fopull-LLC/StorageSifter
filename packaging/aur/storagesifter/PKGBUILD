# Maintainer: Ty Johnston (Fopull LLC) <CHANGE_ME@example.com>
pkgname=storagesifter
pkgver=0.1.0
pkgrel=1
pkgdesc="Fast, GPU-accelerated disk-usage treemap visualizer for Linux"
arch=('x86_64')
url="https://github.com/Fopull-LLC/StorageSifter"
license=('MIT')
depends=('gcc-libs' 'vulkan-icd-loader' 'libxkbcommon' 'wayland' 'libx11' 'libxcursor' 'libxi' 'libxrandr')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
# Checksum of the v0.1.0 source tarball; re-run `updpkgsums` on each version bump.
sha256sums=('fa0c707551f0d782239702d40f780108745bacb6ed9bbefb69d36bc0342bf2db')

prepare() {
    cd "StorageSifter-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "StorageSifter-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release -p app
}

package() {
    cd "StorageSifter-${pkgver}"
    install -Dm755 target/release/storagesifter "$pkgdir/usr/bin/storagesifter"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 packaging/com.fopull.StorageSifter.desktop \
        "$pkgdir/usr/share/applications/com.fopull.StorageSifter.desktop"
    install -Dm644 packaging/com.fopull.StorageSifter.metainfo.xml \
        "$pkgdir/usr/share/metainfo/com.fopull.StorageSifter.metainfo.xml"
    install -Dm644 assets/icons/storagesifter.png \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/com.fopull.StorageSifter.png"
}
